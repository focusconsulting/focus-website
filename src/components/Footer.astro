---
const exploreLinks = ["Our Work", "How We Work", "Capabilities", "About Focus", "Careers", "Let's Talk"];
---

<footer class="bg-[#f7f5f2] px-8 md:px-24 pt-12 pb-8 font-['DM_Sans'] border-t border-[#e0dbd5]">
  <div class="max-w-[1400px] mx-auto flex flex-col md:flex-row justify-between items-start gap-8">
    <div class="font-bold text-xl text-[#e07060] tracking-tight">FOCUS</div>

    <div>
      <div class="font-semibold text-sm text-[#1a1a1a] mb-3">Explore</div>
      <div class="flex flex-col gap-1.5 text-[13px] text-[#8a7e74]">
        {exploreLinks.map((item) => (
          <a href="#" class="text-[#8a7e74] no-underline hover:underline">{item}</a>
        ))}
      </div>
    </div>

    <div>
      <div class="font-semibold text-sm text-[#1a1a1a] mb-3">Get in Touch</div>
      <div class="text-[13px] text-[#8a7e74] leading-[1.7]">
        Focus Consulting LLC<br />
        1015 15th St NW, Suite 600<br />
        Washington, DC 20005
      </div>
    </div>
  </div>

  <div class="max-w-[1400px] mx-auto mt-6 text-xs text-[#8a7e74]">
    Copyright &copy; 2026 FOCUS LLC
  </div>
</footer>
