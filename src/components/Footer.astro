---
const exploreLinks = ["Our Work", "How We Work", "Capabilities", "About Focus", "Careers", "Let's Talk"];
---

<footer class="surface-subtle border-t border-[var(--color-brand-border)] pt-12 pb-8">
  <div class="page-shell flex flex-col items-start justify-between gap-8 md:flex-row md:gap-10">
    <div class="brand-mark text-xl tracking-tight">focus</div>

    <div class="min-w-0">
      <div class="mb-3 text-sm font-semibold text-[var(--color-brand-ink)]">Explore</div>
      <div class="flex flex-col gap-1.5 text-[13px]">
        {exploreLinks.map((item) => (
          <a href="#" class="footer-link">{item}</a>
        ))}
      </div>
    </div>

    <div class="min-w-0">
      <div class="mb-3 text-sm font-semibold text-[var(--color-brand-ink)]">Get in Touch</div>
      <div class="max-w-[18rem] text-[13px] leading-[1.7] text-[var(--color-brand-soft)]">
        Focus Consulting LLC<br />
        1015 15th St NW, Suite 600<br />
        Washington, DC 20005
      </div>
    </div>
  </div>

  <div class="page-shell mt-6 text-xs leading-[1.5] text-[var(--color-brand-soft)]">
    Copyright &copy; 2026 FOCUS Consulting LLC
  </div>
</footer>
