---
interface Impact {
  headline: string;
  description: string;
  link?: string | null;
}

interface Project {
  title: string;
  duration: string;
  client: string;
  clientType: string;
  description: string;
  impact: Impact[];
  categories: string[];
  capabilities: string[];
  role: string;
  primeContractor?: string | null;
}

interface Props {
  projects: Project[];
  eyebrow?: string;
  heading?: string;
}

const { projects, eyebrow = "Portfolio", heading = "All engagements" } = Astro.props;

const allCategories = [...new Set(projects.flatMap((p) => p.categories))].sort();
const allCapabilities = [...new Set(projects.flatMap((p) => p.capabilities))].sort();
const allClientTypes = [...new Set(projects.map((p) => p.clientType))].sort();

const showFilters = projects.length > 1;
---

<section class="portfolio-section surface-subtle py-14 md:py-20">
  <div class="page-shell">
    <div class="mb-10 sm:mb-14">
      <div class="mb-4 text-sm font-semibold uppercase text-[var(--color-brand-accent)]">
        {eyebrow}
      </div>
      <h2 class="section-heading max-w-[30rem]">
        {heading}
      </h2>
    </div>

    {showFilters && (
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-3">
          <div class="text-[0.88rem] font-semibold text-[var(--color-brand-ink)]">Filter</div>
          <a href="#" id="filter-clear" class="hidden text-[0.82rem] font-medium text-[var(--color-brand-accent)] underline underline-offset-2 transition-colors hover:text-[var(--color-brand-ink)]">
            Clear
          </a>
        </div>
        <div class="flex items-end gap-3 md:max-w-[50%]">
          <div class="flex min-w-0 flex-1 flex-col gap-1">
            <label for="filter-category" class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-soft)]">Category</label>
            <div class="relative">
              <select id="filter-category" class="w-full appearance-none rounded-[var(--radius-card)] border border-[var(--color-brand-border)] bg-white px-3 py-1.5 pr-7 text-[0.82rem] font-medium text-[var(--color-brand-ink)] transition-colors hover:border-[var(--color-brand-soft)] focus:border-[var(--color-brand-accent)] focus:outline-none">
                <option value="">All</option>
                {allCategories.map((c) => <option value={c}>{c}</option>)}
              </select>
              <svg class="pointer-events-none absolute right-2 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-[var(--color-brand-soft)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </div>
          </div>

          <div class="flex min-w-0 flex-1 flex-col gap-1">
            <label for="filter-capability" class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-soft)]">Capability</label>
            <div class="relative">
              <select id="filter-capability" class="w-full appearance-none rounded-[var(--radius-card)] border border-[var(--color-brand-border)] bg-white px-3 py-1.5 pr-7 text-[0.82rem] font-medium text-[var(--color-brand-ink)] transition-colors hover:border-[var(--color-brand-soft)] focus:border-[var(--color-brand-accent)] focus:outline-none">
                <option value="">All</option>
                {allCapabilities.map((c) => <option value={c}>{c}</option>)}
              </select>
              <svg class="pointer-events-none absolute right-2 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-[var(--color-brand-soft)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </div>
          </div>

          <div class="flex min-w-0 flex-1 flex-col gap-1">
            <label for="filter-client-type" class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-soft)]">Client Type</label>
            <div class="relative">
              <select id="filter-client-type" class="w-full appearance-none rounded-[var(--radius-card)] border border-[var(--color-brand-border)] bg-white px-3 py-1.5 pr-7 text-[0.82rem] font-medium text-[var(--color-brand-ink)] transition-colors hover:border-[var(--color-brand-soft)] focus:border-[var(--color-brand-accent)] focus:outline-none">
                <option value="">All</option>
                {allClientTypes.map((c) => <option value={c}>{c}</option>)}
              </select>
              <svg class="pointer-events-none absolute right-2 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-[var(--color-brand-soft)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </div>
          </div>
        </div>
      </div>
    )}

    <div id="portfolio-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <div
          class="portfolio-card flex flex-col rounded-[var(--radius-card)] border border-[var(--color-brand-border)] bg-white p-5 transition-shadow hover:shadow-[0_8px_30px_rgba(26,26,26,0.06)] sm:p-6"
          data-categories={JSON.stringify(project.categories)}
          data-capabilities={JSON.stringify(project.capabilities)}
          data-client-type={project.clientType}
        >
          <div class="mb-2 flex flex-wrap gap-1.5">
            {project.categories.map((cat) => (
              <span class="rounded-full bg-[var(--color-brand-surface)] px-2.5 py-0.5 text-[10px] font-semibold uppercase text-[var(--color-brand-soft)]">
                {cat}
              </span>
            ))}
          </div>
          <h3 class="mb-0.5 text-[1.15rem] font-semibold text-[var(--color-brand-ink)]" style="font-family: var(--font-sans);">
            {project.title}
          </h3>
          <div class="mb-3 text-[0.82rem] text-[var(--color-brand-soft)]">
            {project.client} &middot; {project.duration}
          </div>
          <p class="mb-4 text-[0.95rem] leading-[1.65] text-[var(--color-brand-muted)]">
            {project.description}
          </p>
          <div class="mt-auto border-t border-[var(--color-brand-border)] pt-4">
            <div class="mb-1 text-[0.82rem] font-semibold text-[var(--color-brand-accent)]">
              {project.impact[0].headline}
            </div>
            <p class="text-[0.85rem] leading-[1.55] text-[var(--color-brand-soft)]">
              {project.impact[0].description}
            </p>
          </div>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {project.capabilities.map((cap) => (
              <span class="rounded-full border border-[var(--color-brand-border)] px-2.5 py-0.5 text-[10px] font-medium text-[var(--color-brand-soft)]">
                {cap}
              </span>
            ))}
          </div>
          {project.role === "Sub" && project.primeContractor && (
            <div class="mt-3 text-[0.8rem] text-[var(--color-brand-soft)]">
              Sub to {project.primeContractor}
            </div>
          )}
        </div>
      ))}
    </div>

    <p id="portfolio-empty" class="hidden py-12 text-center text-[1rem] text-[var(--color-brand-soft)]">
      No projects match the selected filters.
    </p>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('.portfolio-section');
    if (!root) return;

    const catFilter = root.querySelector('#filter-category');
    const capFilter = root.querySelector('#filter-capability');
    const ctFilter = root.querySelector('#filter-client-type');
    const clearBtn = root.querySelector('#filter-clear');
    const cards = root.querySelectorAll('.portfolio-card');
    const empty = root.querySelector('#portfolio-empty');

    if (!catFilter || !capFilter || !ctFilter) return;

    function applyFilters() {
      const cat = catFilter.value;
      const cap = capFilter.value;
      const ct = ctFilter.value;
      let visible = 0;

      cards.forEach((card) => {
        const categories = JSON.parse(card.dataset.categories);
        const capabilities = JSON.parse(card.dataset.capabilities);
        const clientType = card.dataset.clientType;

        const matchCat = !cat || categories.includes(cat);
        const matchCap = !cap || capabilities.includes(cap);
        const matchCt = !ct || clientType === ct;

        if (matchCat && matchCap && matchCt) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });

      empty.classList.toggle('hidden', visible > 0);
      clearBtn.classList.toggle('hidden', !cat && !cap && !ct);
    }

    catFilter.addEventListener('change', applyFilters);
    capFilter.addEventListener('change', applyFilters);
    ctFilter.addEventListener('change', applyFilters);

    clearBtn.addEventListener('click', (e) => {
      e.preventDefault();
      catFilter.value = '';
      capFilter.value = '';
      ctFilter.value = '';
      applyFilters();
    });
  })();
</script>
