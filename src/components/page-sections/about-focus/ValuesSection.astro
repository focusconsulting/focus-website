---
const values = [
  {
    title: "Outcomes Over Output",
    body:
      'We <strong>measure success by the outcomes</strong> for our clients and users, and we work backwards from those goals.',
  },
  {
    title: "Trusted Public Stewards",
    body:
      'We choose to <strong>maximize value</strong> for the taxpayer, not billable hours, building lasting partnerships through <strong>delivery excellence</strong>.',
  },
  {
    title: "Problems before Solutions",
    body:
      'The best solutions <strong>start with listening</strong> and <strong>discovering the problem</strong>. We value deep collaboration and research that focuses effort where it matters most and avoids wasted work.',
  },
  {
    title: "Managers of One",
    body:
      'We value people who <strong>take initiative</strong>, <strong>prepare</strong>, and <strong>follow through</strong>. Staying lean keeps us accountable, nimble, and able to deliver at speed.',
  },  
];
---

<section class="section-panel-dark py-16 sm:py-20">
  <div class="page-shell">
    <div class="layout-grid">
      <div class="section-content">
      <h1 class="section-heading-inverse mb-4">
        Values
      </h1>
      <div class="grid gap-8 pt-4 sm:grid-cols-2 sm:gap-10">
        {values.map((value) => (
          <article class="border-t border-white/15 pt-5">
            <h3 class="mb-3 text-[1.35rem] font-bold text-white">
              {value.title}
            </h3>
            <p class="text-[0.98rem] text-white/62" set:html={value.body} />
          </article>
        ))}
      </div>
      </div>
    </div>
  </div>
</section>
