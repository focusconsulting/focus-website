---
import whatsNew from '../../../data/whats-new.json';

const domains: {
  name: string;
  description: string;
  projects: string[];
  agencies: string[];
  agencyLogos: Record<string, string>;
  isState: boolean;
}[] = [
  {
    name: "Benefits & Social Programs",
    description: "Modernizing benefit delivery systems, from application and adjudication through payment.",
    projects: ["MA Paid Family Leave", "MN Paid Leave", "NJ Unemployment Insurance"],
    agencies: ["Massachusetts", "New Jersey", "Minnesota"],
    agencyLogos: {
      Massachusetts: "/images/client-logos/ma-map.png",
      "New Jersey": "/images/client-logos/nj-map.png",
      Minnesota: "/images/client-logos/mn-map.png",
    },
    isState: true,
  },
  {
    name: "Healthcare Services",
    description: "Building systems that connect patients, providers, and payers at federal scale.",
    projects: ["Healthcare.gov", "CDC ReportStream", "CMS Cloud (OSRE)", "Preventive Medicaid"],
    agencies: ["CMS", "CDC", "HHS"],
    agencyLogos: {
      CMS: "/images/client-logos/cms-logo.png",
      CDC: "/images/client-logos/cdc-logo.png",
      HHS: "/images/client-logos/hhs-logo.png",
    },
    isState: false,
  },
  {
    name: "Public Interest & Civic Programs",
    description: "Improving access to consular services, grants, childcare, housing, and other essential public services.",
    projects: ["Online Passport Renewal", "FAFSA", "ACF Grants Modernization", "Simpler Grants.gov"],
    agencies: ["Dept of State", "Dept of Education", "IRS"],
    agencyLogos: {
      "Dept of State": "/images/client-logos/dos-logo.png",
      "Dept of Education": "/images/client-logos/doed-logo.svg",
      IRS: "/images/client-logos/irs-logo.png",
    },
    isState: false,
  },
];

function getInitials(label: string) {
  return label.split(" ").map(w => w[0]).join("").slice(0, 3).toUpperCase();
}
---

<section class="py-12 md:py-16">
  <div class="page-shell">
    <h1 class="section-heading mb-8 md:mb-12">
      Our Civic Footprint
    </h1>

    <div class="mb-8 divide-y divide-[var(--color-brand-border)] border-y border-[var(--color-brand-border)] md:mb-12">
      {domains.map((d) => (
        <div class="grid gap-4 py-6 md:grid-cols-12 md:gap-6 md:py-8">
          <div class="md:col-span-4">
            <div class="section-heading mb-2.5 text-[22px]">
              {d.name}
            </div>
            <p class="body-copy mb-5">
              {d.description}
            </p>
          </div>

          <div class="md:col-span-4">
            <div class="meta-label mb-2.5">
              {d.isState ? "States" : "Agencies"}
            </div>
            <div class="flex flex-wrap items-start gap-3">
              {d.agencies.map((label) => {
                const logoSrc = d.agencyLogos[label];
                return (
                  <div class="min-w-0 flex flex-col items-center gap-1">
                    {logoSrc ? (
                      <div class="flex h-14 w-24 items-center justify-center">
                        <img
                          src={logoSrc}
                          alt={`${label} ${d.isState ? "map" : "logo"}`}
                          class="max-h-12 w-auto object-contain"
                          loading="lazy"
                        />
                      </div>
                    ) : (
                      <svg width="36" height="36" viewBox="0 0 36 36">
                        <circle cx="18" cy="18" r="16" fill="none" stroke-width="1.5" opacity="0.4" />
                        <circle cx="18" cy="18" r="12" fill="none" stroke-width="1" opacity="0.25" />
                        <text x="18" y="20" text-anchor="middle" font-size="8" font-weight="600" fill={d.color} font-family="DM Sans, sans-serif">
                          {getInitials(label)}
                        </text>
                      </svg>
                    )}
                    <span class="max-w-[72px] text-center text-xs font-medium text-[var(--color-brand-muted)]">{label}</span>
                  </div>
                );
              })
              }
            </div>
          </div>

          <div class="md:col-span-4 md:border-l md:border-[var(--color-brand-border)] md:pl-8">
            <div class="meta-label mb-2">
              Engagements
            </div>
            <div class="flex flex-col gap-1">
              {d.projects.map((p) => (
                <a
                  href="/our-work"
                  class="text-sm font-medium no-underline hover:underline inline-flex items-center gap-1 hover:opacity-85 transition-opacity"
                  style="color: #3770a5;"
                >
                  {p} <span class="text-xs">→</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="flex flex-col gap-5 pt-6 md:flex-row md:items-baseline md:gap-10 md:pt-8">
      <div class="section-heading whitespace-nowrap text-xl">
        What's New
      </div>
      <div class="flex flex-1 flex-col gap-5 md:flex-row md:gap-8">
        {whatsNew.map((item, i) => (
          <>
            {i > 0 && <div class="divider-soft h-px w-full md:h-auto md:w-px md:self-stretch"></div>}
            <div class="flex-1">
              <div class="mb-1.5 text-[10px] font-semibold uppercase text-[var(--color-brand-accent)]">
                {item.tag}
              </div>
              <p class="mb-1 text-base font-semibold text-[var(--color-brand-ink)]">
                {item.title}
              </p>
              <p class="body-copy m-0 text-[0.95rem]">
                {item.description}
              </p>
              <div class="mt-2 flex items-center gap-3">
                <span class="text-sm text-[var(--color-brand-soft)]">{item.date}</span>
                <a href={item.href} target="_blank" rel="noopener noreferrer" class="text-sm font-medium no-underline hover:underline" style="color: #3770a5;">
                  Read more →
                </a>
              </div>
            </div>
          </>
        ))}
      </div>
    </div>
  </div>
</section>
