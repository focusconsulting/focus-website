---
const domains = [
  {
    name: "Benefits & Social Programs",
    color: "#3aaea0",
    bgColor: "#e8f5f2",
    description: "Modernizing benefit delivery systems — from application through payment",
    projects: ["MA Paid Family Leave", "MN Paid Leave", "NJ Unemployment Insurance"],
    agencies: ["Massachusetts", "New Jersey", "Minnesota", "Maine"],
    isState: true,
  },
  {
    name: "Healthcare Services",
    color: "#3d7db8",
    bgColor: "#e9f0f7",
    description: "Building systems that connect patients, providers, and payers at federal scale",
    projects: ["Healthcare.gov", "CDC ReportStream", "CMS Cloud (OSRE)", "Preventive Medicaid"],
    agencies: ["CMS", "CDC", "HHS"],
    agencyLogos: {
      CMS: "/images/client-logos/cms-logo.png",
      CDC: "/images/client-logos/cdc-logo.png",
      HHS: "/images/client-logos/hhs-logo.png",
    },
    isState: false,
  },
  {
    name: "Public Interest & Civic Programs",
    color: "#e07060",
    bgColor: "#faf0ed",
    description: "Improving access to grants, education, housing, and essential public services",
    projects: ["Online Passport Renewal", "FAFSA", "ACF Grants Modernization", "Simpler Grants.gov"],
    agencies: ["Dept of State", "Dept of Education", "IRS"],
    agencyLogos: {
      "Dept of State": "/images/client-logos/dos-logo.png",
      "Dept of Education": "/images/client-logos/doed-logo.svg",
      IRS: "/images/client-logos/irs-logo.png",
    },
    isState: false,
  },
];

function getInitials(label: string) {
  return label.split(" ").map(w => w[0]).join("").slice(0, 3).toUpperCase();
}
---

<section class="py-12 md:py-16">
  <div class="page-shell">
    <h1 class="section-heading mb-8 md:mb-12">
      Our Civic Footprint
    </h1>

    <div class="mb-8 divide-y divide-[var(--color-brand-border)] border-y border-[var(--color-brand-border)] md:mb-12">
      {domains.map((d) => (
        <div class="grid gap-6 py-6 md:grid-cols-12 md:gap-8 md:py-8">
          <div class="md:col-span-4">
            <div class="section-heading mb-2.5 text-[22px] leading-[1.3]">
              {d.name}
            </div>
            <p class="body-copy mb-5">
              {d.description}
            </p>
          </div>

          <div class="md:col-span-4">
            <div class="meta-label mb-2.5">
              {d.isState ? "States" : "Agencies"}
            </div>
            <div class="flex flex-wrap items-start gap-3">
              {d.isState
                ? d.agencies.map((name) => (
                    <div class="min-w-0 flex flex-col items-center gap-1">
                      <svg width="48" height="40" viewBox="0 0 48 40">
                        <rect x="4" y="4" width="40" height="32" rx="8" fill={d.color} opacity="0.15" />
                        <rect x="4" y="4" width="40" height="32" rx="8" fill="none" stroke={d.color} stroke-width="1.2" opacity="0.5" />
                      </svg>
                      <span class="max-w-[72px] text-center text-[10px] leading-[1.2] text-[var(--color-brand-ink)]">{name}</span>
                    </div>
                  ))
                : d.agencies.map((label) => (
                    <div class="min-w-0 flex flex-col items-center gap-1">
                      {d.agencyLogos?.[label] ? (
                        <div class="flex h-14 w-24 items-center justify-center">
                          <img
                            src={d.agencyLogos[label]}
                            alt={`${label} logo`}
                            class="max-h-12 w-auto object-contain"
                            loading="lazy"
                          />
                        </div>
                      ) : (
                        <svg width="36" height="36" viewBox="0 0 36 36">
                          <circle cx="18" cy="18" r="16" fill="none" stroke={d.color} stroke-width="1.5" opacity="0.4" />
                          <circle cx="18" cy="18" r="12" fill="none" stroke={d.color} stroke-width="1" opacity="0.25" />
                          <text x="18" y="20" text-anchor="middle" font-size="8" font-weight="600" fill={d.color} font-family="DM Sans, sans-serif">
                            {getInitials(label)}
                          </text>
                        </svg>
                      )}
                      <span class="max-w-[56px] text-center text-[9px] font-medium leading-[1.2] text-[var(--color-brand-soft)]">{label}</span>
                    </div>
                  ))
              }
            </div>
          </div>

          <div class="md:col-span-4 md:border-l md:border-[var(--color-brand-border)] md:pl-8">
            <div class="meta-label mb-2">
              Engagements
            </div>
            <div class="flex flex-col gap-1">
              {d.projects.map((p) => (
                <a
                  href="#"
                  class="text-sm font-medium no-underline inline-flex items-center gap-1 hover:opacity-70 transition-opacity"
                  style="color: #3d7db8;"
                >
                  {p} <span class="text-xs">→</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="flex flex-col items-start gap-5 border-t border-[var(--color-brand-border)] pt-6 md:flex-row md:gap-10 md:pt-8">
      <div class="section-heading whitespace-nowrap pt-0.5 text-lg">
        What's New
      </div>
      <div class="flex flex-1 flex-col gap-5 md:flex-row md:gap-8">
        <div class="flex-1">
          <div class="mb-1.5 text-[10px] font-semibold uppercase tracking-[0.05em] text-[#3aaea0]">
            New Project
          </div>
          <a href="#" class="mb-1 block text-sm font-semibold leading-[1.4] text-[var(--color-brand-ink)] no-underline">
            Physician's Assistant Compact System
          </a>
          <p class="body-copy m-0 text-[0.95rem] leading-[1.5]">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.
          </p>
        </div>
        <!-- Divider -->
        <div class="divider-soft h-px w-full md:h-auto md:w-px md:self-stretch"></div>
        <div class="flex-1">
          <div class="mb-1.5 text-[10px] font-semibold uppercase tracking-[0.05em] text-[#3d7db8]">
            In the News
          </div>
          <a href="#" class="mb-1 block text-sm font-semibold leading-[1.4] text-[var(--color-brand-ink)] no-underline">
            We helped save $70 million for the MN Department of Employment and Economic Development
          </a>
          <p class="body-copy m-0 text-[0.95rem] leading-[1.5]">
            A modernization effort that reduced costs and improved service delivery for Minnesota workers.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
