---
const evidenceCards = [
  {
    category: "Public Interest",
    metric: "2 million",
    headline: "Passport renewals in 5 months",
    bodyHtml:
      "We modernized passport renewals from the ground up as a mobile-first, fully accessible system that takes <b>only 5 minutes to complete</b>.",
    href: "#",
  },
  {
    category: "Benefits",
    metric: "$4.5+ billion",
    headline: "Massachusetts Paid Leave benefits since 2021",
    bodyHtml:
      "We built resilient <strong>adjudication</strong> and <strong>payment</strong> systems so that claimants can get key benefits on time.",
    href: "#",
  },
];
---

<section class="section-panel-dark py-14 md:py-16">
  <div class="page-shell">
    <div class="flex flex-col gap-10 border-b border-white/[0.12] pb-10 md:flex-row md:gap-16">
      {evidenceCards.map((card, index) => (
        <>
          <div class="flex flex-1 flex-col">
            <div class="mb-1 text-xs font-semibold uppercase text-[var(--color-white)]/75">
              {card.category}
            </div>
            <div class="mb-1 font-['DM_Serif_Display'] text-[42px] font-normal text-[var(--color-brand-accent-inverse)] sm:text-[58px]">
              {card.metric}
            </div>
            <div class="mb-4 font-['DM_Serif_Display'] text-[19px] font-normal text-white sm:text-[21px]">
              {card.headline}
            </div>
            <p class="body-copy-inverse mb-6 max-w-[460px]" set:html={card.bodyHtml}></p>
            {/* <a href={card.href} class="cta-outline-inverse mt-auto">
              Read More <span class="text-[15px]">&rarr;</span>
            </a> */}
          </div>

          {index < evidenceCards.length - 1 && (
            <div class="h-px w-full bg-white/[0.12] md:h-auto md:w-px"></div>
          )}
        </>
      ))}
    </div>

    <p class="body-copy-inverse mt-6 text-center">
      Engagements we led, outcomes we owned, systems still running.
    </p>
    <div class="mt-4 text-center">
      <a href="#" class="text-[1.3rem] font-semibold text-[var(--color-brand-accent-inverse)] underline decoration-[var(--color-brand-accent-inverse)]/45 underline-offset-3 transition-colors hover:text-white hover:decoration-[var(--color-brand-accent-inverse)]">
        Read more about our work <span>&rarr;</span>
      </a>
    </div>
  </div>
</section>
