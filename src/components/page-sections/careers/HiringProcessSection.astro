---
const steps = [
  {
    duration: "30 min",
    title: "Introductory call",
    body:
      "A conversation with a future colleague about your background and whether there's mutual interest.",
    illustration: "call",
  },
  {
    duration: "60-90 min",
    title: "Technical interview",
    body:
      "Focused on the work you'd actually be doing. Engineers complete a take-home exercise first; other disciplines work through a project scenario.",
    illustration: "technical",
  },
  {
    duration: "60 min",
    title: "Behavioral interview",
    body:
      "We discuss how you work and collaborate with your colleagues and clients.",
    illustration: "behavioral",
  },
  {
    duration: "Less than a week",
    title: "Offer",
    body:
      "We will work speedily to give you an offer within a few days.",
    illustration: "offer",
  },
];
---

<section class="section-panel-dark py-16 sm:py-20">
  <div class="page-shell">
    <div class="layout-grid">
      <div class="col-span-12">
      <h1 class="section-heading-inverse">
        Hiring Process
      </h1>
      <p class="mt-4 max-w-[52rem] text-[1.05rem] text-white/72">
        Our hiring process looks for practical day to day skills needed for our work. No gimmicks or trick questions. Our hiring process usually takes two weeks from the first session to offer.
      </p>

      <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-10">
        {steps.map((step) => (
          <article>
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-full bg-[var(--color-brand-accent)]" aria-hidden="true">
              {step.illustration === "call" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
                </svg>
              )}
              {step.illustration === "technical" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                  <line x1="8" y1="21" x2="16" y2="21" />
                  <line x1="12" y1="17" x2="12" y2="21" />
                </svg>
              )}
              {step.illustration === "behavioral" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                </svg>
              )}
              {step.illustration === "offer" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <path d="M9 15l2 2 4-4" />
                </svg>
              )}
            </div>
            <div class="text-[0.85rem] text-white/55">{step.duration}</div>
            <h3 class="mt-1 text-[1.4rem] text-white">
              {step.title}
            </h3>
            <p class="body-copy-inverse mt-3 text-[0.95rem]">
              {step.body}
            </p>
          </article>
        ))}
      </div>
      </div>
    </div>
  </div>
</section>
