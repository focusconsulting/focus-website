---
const benefits = [
  {
    title: "Competitive Salary",
    body:
      "Competitive compensation to the Washington D.C. market, with transparent levels and salary bands.",
  },
  {
    title: "Time off",
    body:
      "26 days off per year: 15 days PTO plus 11 federal holidays.",
  },
  {
    title: "Health Insurance",
    body:
      "Medical, dental and vision coverage for employees and their dependents.",
  },
  {
    title: "Unlimited Sick Time",
    body:
      "No need to spend your vacation days in bed.",
  },
  {
    title: "Life & Disability Insurance",
    body:
      "100% company paid life, short-term and long-term disability insurance.",
  },
  {
    title: "Pre-Tax Spending Accounts",
    body:
      "Pre-tax medical flexible spending accounts (FSA) and dependent care assistance program (DCAP).",
  },
  {
    title: "Paid Family & Medical Leave",
    body:
      "Up to 12 weeks of fully paid parental or medical leave for eligible employees.",
  },
  {
    title: "401(K)",
    body:
      "We provide 401(k) contributions through Human Interest.",
  },
  {
    title: "Professional Development",
    body:
      "$1,000 annual budget to take classes, attend conferences, or buy subscriptions.",
  },
  {
    title: "Fully Remote",
    body:
      "Work from anywhere within the continental US.",
  },
  {
    title: "Bonus",
    body:
      "Yearly bonus based on your performance and company outcomes.",
  },
];
---

<section id="benefits-perks" class="section-panel-dark py-16 sm:py-20">
  <div class="page-shell">
    <div class="layout-grid">
      <div class="section-content">
      <div class="mb-8 flex items-end justify-between gap-6">
        <h1 class="section-heading-inverse">
          Benefits & Perks
        </h1>
        <button
          type="button"
          class="benefits-toggle shrink-0 cursor-pointer text-[0.78rem] font-semibold uppercase text-white/55 transition-colors hover:text-white"
          aria-expanded="false"
        >
          Expand
        </button>
      </div>

      <div class="benefits-accordion border-t border-white/[0.12]">
        {benefits.map((benefit) => (
          <details class="group border-b border-white/[0.12]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-3.5 marker:content-none">
              <span class="flex-1 text-[1.16rem] font-bold text-white sm:text-[1.35rem]">{benefit.title}</span>
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-white/35 text-[0.8rem] leading-none text-white/75 transition-transform duration-200 group-open:rotate-45">
                +
              </span>
            </summary>
            <div class="pb-4 pr-10">
              <p class="text-[0.98rem] text-white/62">
                {benefit.body}
              </p>
            </div>
          </details>
        ))}
      </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.getElementById('benefits-perks');
    const toggle = root?.querySelector('.benefits-toggle');
    const detailsList = root?.querySelectorAll('.benefits-accordion details');

    if (toggle && detailsList?.length) {
      const syncLabel = () => {
        const allOpen = Array.from(detailsList).every((item) => item.open);
        toggle.textContent = allOpen ? 'Collapse' : 'Expand';
        toggle.setAttribute('aria-expanded', allOpen ? 'true' : 'false');
      };

      toggle.addEventListener('click', () => {
        const allOpen = Array.from(detailsList).every((item) => item.open);
        detailsList.forEach((item) => {
          item.open = allOpen ? false : true;
        });
        syncLabel();
      });

      detailsList.forEach((item) => {
        item.addEventListener('toggle', syncLabel);
      });

      syncLabel();
    }
  })();
</script>
