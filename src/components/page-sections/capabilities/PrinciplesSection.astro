---
const principles = [
  {
    title: "We understand before we build",
    body:
      "We start with the policy context, operational reality, and constraints your teams are already managing. That keeps delivery grounded in what the service actually needs.",
  },
  {
    title: "Every discipline works on the problem at the same time",
    body:
      "Research, design, engineering, delivery, and product work as one team. Decisions happen faster because the people responsible for outcomes are in the room together.",
  },
  {
    title: "We deliver in working increments",
    body:
      "We break modernization into testable slices so teams can validate progress early, reduce risk, and keep momentum without waiting for a big-bang launch.",
  },
  {
    title: "We're accountable for outcomes",
    body:
      "We measure the health of the work through real service improvements, not presentation decks. The goal is a system people can use and teams can run with confidence.",
  },
  {
    title: "We build your team's capacity as we go",
    body:
      "Documentation, pairing, governance patterns, and decision records are part of the engagement. We leave behind clearer systems and stronger internal capability.",
  },
];
---

<section id="how-we-work-principles" class="surface-subtle py-14 sm:py-18">
  <div class="page-shell">
    <div class="layout-grid">
      <div class="section-content">
      <div class="mb-3 text-sm font-semibold uppercase tracking-[0.08em] text-[var(--color-brand-accent)]">
        Approach
      </div>
      <div class="mb-8 flex items-end justify-between gap-6">
        <h1 class="section-heading">
          How We Partner
        </h1>
        <button
          type="button"
          class="how-we-work-toggle shrink-0 cursor-pointer text-[0.78rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-brand-soft)] transition-colors hover:text-[var(--color-brand-accent)]"
          aria-expanded="false"
        >
          Expand
        </button>
      </div>

      <div class="how-we-work-accordion border-t border-[var(--color-brand-border)]">
        {principles.map((principle, index) => (
          <details class="group border-b border-[var(--color-brand-border)]">
            <summary class="flex cursor-pointer list-none items-center gap-4 py-4 marker:content-none">
              <span class="w-8 shrink-0 text-[0.75rem] font-semibold tracking-[0.08em] text-[var(--color-brand-soft)]">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class="flex-1 text-[1.16rem] leading-[1.3] font-bold text-[var(--color-brand-ink)] sm:text-[1.35rem]">
                {principle.title}
              </span>
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-[var(--color-brand-border)] text-[var(--color-brand-soft)] transition-transform duration-200 group-open:rotate-45">
                +
              </span>
            </summary>
            <div class="pb-5 pl-12 pr-10">
              <p class="body-copy text-[0.98rem]">
                {principle.body}
              </p>
            </div>
          </details>
        ))}
      </div>

      <div class="mt-8">
        <a href="/about-focus" class="cta-primary px-5 py-3 text-[0.92rem] sm:px-7 sm:py-3.5 sm:text-[1rem]">
          See what anchors our approach <span class="text-lg">→</span>
        </a>
      </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const root = document.getElementById('how-we-work-principles');
  const toggle = root?.querySelector('.how-we-work-toggle');
  const detailsList = root?.querySelectorAll('.how-we-work-accordion details');

  if (toggle && detailsList?.length) {
    const syncLabel = () => {
      const allOpen = Array.from(detailsList).every((item) => item.open);
      toggle.textContent = allOpen ? 'Collapse' : 'Expand';
      toggle.setAttribute('aria-expanded', allOpen ? 'true' : 'false');
    };

    toggle.addEventListener('click', () => {
      const allOpen = Array.from(detailsList).every((item) => item.open);
      detailsList.forEach((item) => {
        item.open = allOpen ? false : true;
      });
      syncLabel();
    });

    detailsList.forEach((item) => {
      item.addEventListener('toggle', syncLabel);
    });

    syncLabel();
  }
</script>
