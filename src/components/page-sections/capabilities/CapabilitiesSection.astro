---
type Callout = { title: string; body?: string; bodyNote?: string; items: string[] };
type Capability = { id: string; label: string; title: string; description: string; callouts: Callout[] };

const capabilities: Capability[] = [
  {
    id: "digital-modernization",
    label: "Digital Modernization",
    title: "Digital Modernization",
    description:
      "We modernize legacy systems by reducing delivery risk early, working through integration constraints first, and creating a path from fragile platforms to resilient services.",
    callouts: [
      {
        title: "Strategy",
        body:
          "We usually start with a mixed team of platform engineers, product leadership, and delivery management embedded with client stakeholders. That lets us map dependencies, validate migration paths, and decide where parallel builds make sense versus where in-place enhancement is the safer move.",
        items: [
          "Parallel replacement when the operational risk of direct migration is too high",
          "Incremental modernization when live systems must keep serving without interruption",
          "Staffing that blends senior modernization leads with engineers who can ship inside legacy constraints",
        ],
      },
      {
        title: "Success Stories",
        items: [
          "We are leading the effort to make the FAFSA loan program more resilient across multiple vendor systems by improving end-to-end testing and system observability.",
          "Our team is building a modern passport adjudication system to replace the on-prem legacy system while preserving integration with down-stream systems.",
          "We are incrementally modernizing the Grant.gov system while the overall system is services users. We started with the search functionality an are now working on applications.",
        ],
      },
    ],
  },
  {
    id: "adjudicated-benefits",
    label: "Adjudicated Benefits",
    title: "Adjudicated Benefits",
    description:
      "We understand, user research, and delivery benefits programs that depend on complex eligibility rules, operational consistency, and case handling, helping agencies improve both service delivery and adjudication integrity.",
    callouts: [
      {
        title: "Strategy",
        body:
          "Our approach combines service understanding, rules analysis, and delivery planning so modernization work reflects how adjudication actually happens. We typically staff these engagements with product, policy-aware delivery leads, and engineers who can work through case workflows, decision logic, and integration dependencies together.",
        items: [
          "Service and workflow mapping across intake, review, and determination steps",
          "Delivery teams that can translate policy and operational rules into usable systems"          
        ],
      },
      {
        title: "Success Stories",
        items: [
          "We're working closely with adjudicator officers across different sites to ensure that a modernized Passport Adjudication system serves their needs.",
          "In Massachusets, our team led the effort to implement the system that coordinates and integrates the application, to adjudication, to payments systems.",
        ],
      },
    ],
  },
  {
    id: "ai-emerging-technologies",
    label: "AI & Emerging Technologies",
    title: "AI & Emerging Technologies",
    description:
      "We help agencies apply AI where it improves service delivery in real workflows, with clear evaluation criteria, strong operational controls, and realistic implementation plans.",
    callouts: [
      {
        title: "Strategy",
        body:
          "We rely on evals, structured evaluation frameworks, to measure and enforce consistency of LLM outputs before and after changes, so teams can ship with confidence rather than guesswork. We bias toward narrow, high-value implementations first, then expand once accuracy, trust, and operational fit are proven.",
        bodyNote: '<a href="https://playbook.focusconsulting.io/playbooks/" target="_blank" rel="noopener noreferrer">Learn more</a> about our approach to using AI assistance for more effective discovery, design, and implementation.',
        items: [
          "Rapid discovery to identify practical AI use cases tied to mission outcomes",
          "Eval-driven development to ensure LLM output consistency across iterations and deployments",
          "Prototype-first delivery with human review built into the workflow",
          "Cross-functional staffing that covers model behavior, integration, and change management",          
        ],
      },
      {
        title: "Success Stories",
        body:
          "Starter project blurbs that can be replaced with named case studies later.",
        items: [
          "At the Department of State, we're exploring how best LLMs can provide contextual support for Passport Adjudication Specialists by proactively analyzing the submission data and surfacing insights whenever an agent loads one for review.",
          "Government has a lot of source material, from legislation to rules, committee meetings, and public hearings. LLMs now allow us to do deep research on these source materials to understand existing context better. For our upcoming kickoffs, we're setting up reusable AI skills and workflows to perform extensive desk research from existing sources, generate documentation and visualizations that align our internal team ahead of kickoff, and prepares us to ask right questions when we meet our stakeholders.",
        ],
      },
    ],
  },
  {
    id: "security-compliance",
    label: "Security & Compliance",
    title: "Security & Compliance",
    description:
      "We integrate security into delivery from the beginning so teams can ship critical services with stronger controls, clearer compliance posture, and fewer surprises late in the program.",
    callouts: [
      {
        title: "Strategy",
        body:
          "We embed security work as part of delivery, not as an external gate at the end. That usually means platform and application engineers working alongside security specialists, with controls designed into architecture, release workflows, and operational practice from day one.",
        items: [
          "Zero-trust oriented architecture and access design",
          "Embedded security review inside sprint delivery rather than separate audit cycles",
          "Teams staffed to balance compliance requirements with practical engineering throughput",
        ],
      },
      {
        title: "Success Stories",
        items: [
          "At the Department of State, we create the consular division's first cloud infrastructure platform as part of our work on Online Passport Renewal, transferred it to the security team, and played a key role to achieving both application and platform ATO in collaboration with the security team.",
          "At FAFSA, we're embedding security considerations into our e2e testing and observability work to catch issues before production across multi-vendor systems.",
        ],
      },
    ],
  },
  // {
  //   id: "enterprise-data",
  //   label: "Enterprise Data",
  //   title: "Enterprise Data",
  //   description:
  //     "We build data platforms and pipelines that improve reliability, governance, and visibility across systems, making it easier for agencies to use data operationally and responsibly.",
  //   callouts: [
  //     {
  //       title: "Strategy",
  //       body:
  //         "Our delivery approach usually combines data engineering, platform support, and program coordination so pipeline work is grounded in operational realities. We focus on source-of-truth questions early, then design for governance, scalability, and maintainability as the system matures.",
  //       items: [
  //         "ETL and integration strategy shaped around existing agency systems",
  //         "Delivery teams that can handle ingestion, transformation, and operational reporting together",
  //         "Governance-first planning so reliability and compliance are built into the platform",
  //       ],
  //     },
  //     {
  //       title: "Success Stories",
  //       body:
  //         "Placeholder blurbs for early content on the capabilities page.",
  //       items: [
  //         "Designed a shared data pipeline approach that reduced reconciliation effort across disconnected systems and improved confidence in operational reporting.",
  //         "Supported an agency team in scaling data workflows for higher-volume processing while improving governance around access, lineage, and quality checks.",
  //       ],
  //     },
  //   ],
  // },
];
---

<section class="capabilities-section section-panel-dark py-18 sm:py-22">
  <div class="page-shell">
    <div class="mb-10 text-left sm:mb-14">
      <div class="mb-4 text-sm font-semibold uppercase text-[var(--color-brand-accent-inverse)]">Capabilities</div>
      <h2 class="section-heading-inverse">
        Expertise for the shape of government work.
      </h2>
    </div>

    <div class="capabilities-grid">
      <input
        type="radio"
        name="capabilities"
        id="capability-none"
        class="capability-toggle"
        checked
      />
      <label for="capability-none" class="sr-only">No capability selected</label>
      {capabilities.map((capability) => (
        <input
          type="radio"
          name="capabilities"
          id={`capability-${capability.id}`}
          class="capability-toggle"
        />
      ))}

      <div class="capabilities-nav">
        {capabilities.map((capability, index) => (
          <label class="capability-nav-card" for={`capability-${capability.id}`}>
            <span class="capability-index">{String(index + 1).padStart(2, "0")}</span>
            <span class="capability-label capability-selector-heading">{capability.label}</span>

            <article class="capability-panel capability-panel-mobile">
              <div class="capability-panel-header">
                <p class="max-w-[48rem] text-[1rem] text-[var(--color-brand-muted)]">
                  {capability.description}
                </p>
              </div>

              <div class="mt-8 grid gap-4">
                {capability.callouts.map((pillar) => (
                  <section class="capability-pillar">
                    <h4 class="capability-meta-heading mb-4 text-[1rem] font-semibold uppercase text-[var(--color-brand-muted)]">
                      {pillar.title}
                    </h4>
                    <p class="mb-5 max-w-[58rem] text-[0.98rem] text-[var(--color-brand-muted)]">
                      {pillar.body}
                    </p>
                    <ul class="grid gap-2.5 text-[0.98rem] text-[var(--color-brand-muted)]">
                      {pillar.items.map((item) => (
                        <li class="flex gap-3">
                          <span class="mt-[0.62rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-brand-accent)]"></span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                    {pillar.bodyNote && (
                      <p class="mt-4 max-w-[58rem] text-[0.98rem] text-[var(--color-brand-muted)] [&_a]:font-medium [&_a]:text-[var(--color-brand-accent)] [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:opacity-80" set:html={pillar.bodyNote} />
                    )}
                  </section>
                ))}
              </div>
            </article>
          </label>
        ))}
      </div>

      <div class="capabilities-panels">
        {capabilities.map((capability) => (
          <article id={`panel-${capability.id}`} class="capability-panel capability-panel-desktop">
            <div class="capability-panel-header">
              <h3 class="capability-title mb-4 text-[1.8rem] font-medium text-[var(--color-brand-ink)] sm:text-[2.2rem]">
                {capability.title}
              </h3>
              <p class="max-w-[48rem] text-[1.05rem] text-[var(--color-brand-muted)] sm:text-[1.22rem]">
                {capability.description}
              </p>
            </div>

            <div class="mt-8 grid gap-4 sm:mt-10 sm:gap-5">
              {capability.callouts.map((pillar) => (
                <section class="capability-pillar">
                  <h4 class="capability-meta-heading mb-4 text-[1.1rem] font-semibold uppercase text-[var(--color-brand-muted)]">
                    {pillar.title}
                  </h4>
                  <p class="mb-5 max-w-[58rem] text-[1rem] text-[var(--color-brand-muted)] sm:text-[1.05rem]">
                    {pillar.body}
                  </p>
                  <ul class="grid gap-2.5 text-[1rem] text-[var(--color-brand-muted)] sm:text-[1.05rem]">
                    {pillar.items.map((item) => (
                      <li class="flex gap-3">
                        <span class="mt-[0.62rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-brand-accent)]"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  {pillar.bodyNote && (
                    <p class="mt-4 max-w-[58rem] text-[1rem] text-[var(--color-brand-muted)] sm:text-[1.05rem] [&_a]:font-medium [&_a]:text-[var(--color-brand-accent)] [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:opacity-80" set:html={pillar.bodyNote} />
                  )}
                </section>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .capability-selector-heading,
  .capability-title,
  .capability-meta-heading {
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .capabilities-grid {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .capability-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .capabilities-nav {
    display: grid;
    gap: 1rem;
  }

  .capability-nav-card {
    display: grid;
    gap: 0.375rem;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-card);
    padding: 1.25rem 1.5rem;
    color: white;
    cursor: pointer;
    transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }

  .capability-nav-card:hover {
    transform: translateY(-1px);
    border-color: white;
  }

  .capability-index {
    font-size: 0.9rem;
    color: var(--color-brand-accent-inverse);
  }

  .capability-label {
    font-size: 1.35rem;
    font-weight: 600;
  }

  .capabilities-panels {
    position: relative;
    display: none;
  }

  .capability-panel {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    background:
      radial-gradient(circle at top right, rgba(224, 112, 96, 0.09), transparent 25%),
      linear-gradient(180deg, #fcfbf9 0%, #f4f0ea 100%);
    padding: 1.5rem;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.18);
  }

  .capability-panel-mobile {
    display: none;
    margin-top: 1.25rem;
    overflow: visible;
    border-radius: 0;
    background: transparent;
    padding: 1rem 0 0;
    box-shadow: none;
  }


  .capability-panel-desktop {
    display: none;
  }

  .capability-panel-header {
    position: relative;
    z-index: 1;
  }

  .capability-pillar {
    position: relative;
    z-index: 1;
    padding: 0;
  }

  .capability-pillar + .capability-pillar {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(26, 26, 26, 0.1);
  }

  #capability-digital-modernization:checked ~ .capabilities-nav label[for="capability-digital-modernization"],
  #capability-ai-emerging-technologies:checked ~ .capabilities-nav label[for="capability-ai-emerging-technologies"],
  #capability-security-compliance:checked ~ .capabilities-nav label[for="capability-security-compliance"],
  #capability-enterprise-data:checked ~ .capabilities-nav label[for="capability-enterprise-data"],
  #capability-adjudicated-benefits:checked ~ .capabilities-nav label[for="capability-adjudicated-benefits"] {
    background: #fcfbf9;
    border-color: #fcfbf9;
    color: var(--color-brand-ink);
  }

  #capability-digital-modernization:checked ~ .capabilities-nav label[for="capability-digital-modernization"] .capability-index,
  #capability-ai-emerging-technologies:checked ~ .capabilities-nav label[for="capability-ai-emerging-technologies"] .capability-index,
  #capability-security-compliance:checked ~ .capabilities-nav label[for="capability-security-compliance"] .capability-index,
  #capability-enterprise-data:checked ~ .capabilities-nav label[for="capability-enterprise-data"] .capability-index,
  #capability-adjudicated-benefits:checked ~ .capabilities-nav label[for="capability-adjudicated-benefits"] .capability-index {
    color: var(--color-brand-accent);
  }

  #capability-digital-modernization:checked ~ .capabilities-panels #panel-digital-modernization,
  #capability-adjudicated-benefits:checked ~ .capabilities-panels #panel-adjudicated-benefits,
  #capability-ai-emerging-technologies:checked ~ .capabilities-panels #panel-ai-emerging-technologies,
  #capability-security-compliance:checked ~ .capabilities-panels #panel-security-compliance,
  #capability-enterprise-data:checked ~ .capabilities-panels #panel-enterprise-data {
    display: block;
  }

  #capability-digital-modernization:checked ~ .capabilities-nav label[for="capability-digital-modernization"] .capability-panel-mobile,
  #capability-ai-emerging-technologies:checked ~ .capabilities-nav label[for="capability-ai-emerging-technologies"] .capability-panel-mobile,
  #capability-security-compliance:checked ~ .capabilities-nav label[for="capability-security-compliance"] .capability-panel-mobile,
  #capability-enterprise-data:checked ~ .capabilities-nav label[for="capability-enterprise-data"] .capability-panel-mobile,
  #capability-adjudicated-benefits:checked ~ .capabilities-nav label[for="capability-adjudicated-benefits"] .capability-panel-mobile {
    display: block;
  }

  @media (max-width: 959px) {
    #capability-none:checked ~ .capabilities-nav label {
      background: transparent;
      border-color: rgba(255, 255, 255, 0.72);
      color: white;
    }

    #capability-none:checked ~ .capabilities-nav label .capability-index {
      color: var(--color-brand-accent-inverse);
    }
  }

  @media (min-width: 960px) {
    .capability-label {
      font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    }

    #capability-none:checked ~ .capabilities-nav label[for="capability-digital-modernization"] {
      background: #fcfbf9;
      border-color: #fcfbf9;
      color: var(--color-brand-ink);
    }

    #capability-none:checked ~ .capabilities-nav label[for="capability-digital-modernization"] .capability-index {
      color: var(--color-brand-accent);
    }

    #capability-none:checked ~ .capabilities-panels #panel-digital-modernization {
      display: block;
    }

    .capabilities-grid {
      grid-template-columns: minmax(15rem, 31%) minmax(0, 1fr);
      gap: 2rem;
    }

    .capability-panel {
      min-height: 56rem;
      padding: 2.25rem;
    }

    .capability-panel-mobile {
      display: none !important;
    }

    .capabilities-nav {
      position: sticky;
      top: 2rem;
    }

    .capabilities-panels {
      display: block;
    }

    .capability-pillar + .capability-pillar {
      margin-top: 1.75rem;
      padding-top: 1.75rem;
    }
  }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector('.capabilities-section');
    if (!root) return;

    const neutral = root.querySelector('#capability-none');
    const first = root.querySelector('#capability-digital-modernization');
    const cards = root.querySelectorAll('.capability-nav-card');
    if (!(neutral instanceof HTMLInputElement) || !(first instanceof HTMLInputElement)) return;

    const syncDefaultState = () => {
      if (window.matchMedia('(min-width: 960px)').matches) {
        first.checked = true;
      } else {
        neutral.checked = true;
      }
    };

    const scrollSectionToTop = () => {
      const top = root.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({
        top: Math.max(top, 0),
        behavior: 'smooth',
      });
    };

    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        const radioId = card.getAttribute('for');
        const radio = radioId && root.querySelector('#' + CSS.escape(radioId));
        if (radio instanceof HTMLInputElement && radio.checked && !window.matchMedia('(min-width: 960px)').matches) {
          e.preventDefault();
          neutral.checked = true;
          return;
        }
        requestAnimationFrame(() => {
          requestAnimationFrame(scrollSectionToTop);
        });
      });
    });

    syncDefaultState();
  })();
</script>
