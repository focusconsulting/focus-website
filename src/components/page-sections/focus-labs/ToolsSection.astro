---
const tools = [
  {
    name: "Formspec",
    description: "Build AI-assisted, complex forms in an afternoon.",
    href: "https://formspec.org/",
  },
  {
    name: "Django Cotton USWDS",
    description: "USWDS components as Django Cotton templates.",
    href: "https://github.com/focusconsulting/django-cotton-uswds",
  },
];
---

<section class="surface-subtle py-14 sm:py-18">
  <div class="page-shell">
    <div class="mb-10 sm:mb-14">
      <div class="mb-4 text-sm font-semibold uppercase text-[var(--color-brand-accent)]">Tools</div>
      <h2 class="section-heading">
        What we're building
      </h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {tools.map((tool) => (
        <div class="rounded-[var(--radius-card)] border border-[var(--color-brand-border)] bg-white p-6 sm:p-8">
          <h3 class="text-[1.35rem] font-semibold text-[var(--color-brand-ink)]">
            {tool.name}
          </h3>
          <p class="body-copy mt-3">
            {tool.description}
          </p>
          <a
            href={tool.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-flex items-center gap-1.5 text-[0.95rem] font-medium text-[var(--color-brand-accent)] no-underline transition-colors hover:text-[#9a3409]"
          >
            Learn more <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
