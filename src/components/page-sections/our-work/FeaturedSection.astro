---
import allProjects from '../../../data/projects.json';

const featuredProjects = allProjects.filter((p) => p.portfolio && p.featured);
const formatProjectDates = (project) => `${project.projectStartDate} – ${project.projectEndDate ?? 'Present'}`;
---

<section class="section-panel-dark py-14 md:py-20">
  <div class="page-shell">
    <div class="mb-10 sm:mb-14">
      <div class="mb-4 text-sm font-semibold uppercase text-[var(--color-brand-accent-inverse)]">
        Featured
      </div>
      <h2 class="section-heading-inverse">
        Work that changed how services reach people.
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {featuredProjects.map((project) => (
        <div class="featured-card flex flex-col rounded-[var(--radius-card)] p-6 shadow-[0_28px_70px_rgba(0,0,0,0.18)] sm:p-8">
          <h3 class="mb-1 font-serif text-[1.35rem] font-normal text-[var(--color-brand-ink)] sm:text-[1.5rem]">
            {project.title}
          </h3>
          <div class="mb-4 text-[0.85rem] text-[var(--color-brand-soft)]">
            {project.client} &middot; {formatProjectDates(project)}
          </div>
          <p class="body-copy mb-6 max-w-[460px]">
            {project.description}
          </p>

          {project.impact.length > 0 && (
            <div class="border-t border-[rgba(26,26,26,0.1)] pt-5">
              <div class="mb-2 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-soft)]">
                Impact
              </div>
              <div class="grid gap-3">
                {project.impact.map((item) => (
                  <div>
                    <div class="font-['DM_Serif_Display'] text-[1.25rem] font-normal text-[var(--color-brand-accent)]">
                      {item.headline}
                    </div>
                    <p class="body-copy">
                      {item.description}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {project.clientQuote && (
            <div class="mt-6 border-t border-[rgba(26,26,26,0.1)] pt-5">
              <blockquote class="mb-2 text-lg leading-[1.65] text-[var(--color-brand-muted)] font-serif italic">
                &ldquo;{project.clientQuote.quote}&rdquo;
              </blockquote>
              <div class="text-sm font-medium text-[var(--color-brand-soft)]">
                — {project.clientQuote.name}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-card {
    background:
      radial-gradient(circle at top right, rgba(224, 112, 96, 0.09), transparent 25%),
      linear-gradient(180deg, #fcfbf9 0%, #f4f0ea 100%);
  }
</style>
