---
import allProjects from '../../../data/projects.json';

const featuredProjects = allProjects.filter((p) => p.featured);
---

<section class="section-panel-dark py-14 md:py-20">
  <div class="page-shell">
    <div class="mb-10 sm:mb-14">
      <div class="mb-4 text-sm font-semibold uppercase text-[var(--color-brand-accent-inverse)]">
        Featured
      </div>
      <h2 class="section-heading-inverse max-w-[36rem]">
        Work that changed how services reach people.
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {featuredProjects.map((project) => (
        <a
          href={project.href || "#"}
          class="featured-card group flex flex-col rounded-[var(--radius-card)] p-6 shadow-[0_28px_70px_rgba(0,0,0,0.18)] sm:p-8"
        >
          <div class="mb-1 text-xs font-semibold uppercase text-[var(--color-brand-accent)]">
            {project.categories[0]}
          </div>
          <div class="mb-1 text-[0.9rem] text-[var(--color-brand-soft)]">
            {project.client}
          </div>
          <h3 class="mb-1 font-['DM_Serif_Display'] text-[1.6rem] font-normal text-[var(--color-brand-ink)] sm:text-[1.85rem]">
            {project.title}
          </h3>
          <div class="mb-4 text-[0.85rem] text-[var(--color-brand-soft)]">
            {project.duration}
          </div>
          <p class="body-copy mb-6 max-w-[460px]">
            {project.description}
          </p>

          <div class="mt-auto border-t border-[rgba(26,26,26,0.1)] pt-5">
            <div class="mb-0.5 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-soft)]">
              Impact
            </div>
            <div class="grid gap-3">
              {project.impact.map((item) => (
                <div>
                  <div class="font-['DM_Serif_Display'] text-[1.25rem] font-normal text-[var(--color-brand-accent)]">
                    {item.headline}
                  </div>
                  <p class="text-[0.88rem] leading-[1.6] text-[var(--color-brand-muted)]">
                    {item.description}
                  </p>
                </div>
              ))}
            </div>
          </div>

          {project.clientQuote && (
            <div class="mt-6 border-t border-[rgba(26,26,26,0.1)] pt-5">
              <blockquote class="mb-2 text-[0.95rem] italic leading-[1.65] text-[var(--color-brand-muted)]">
                &ldquo;{project.clientQuote.quote}&rdquo;
              </blockquote>
              <div class="text-[0.82rem] font-medium text-[var(--color-brand-soft)]">
                — {project.clientQuote.name}
              </div>
            </div>
          )}

          <div class="mt-6 text-[0.95rem] font-semibold text-[var(--color-brand-ink)] underline decoration-transparent underline-offset-3 transition-all group-hover:text-[var(--color-brand-accent)] group-hover:decoration-[var(--color-brand-accent)]">
            Read case study <span>&rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-card {
    background:
      radial-gradient(circle at top right, rgba(224, 112, 96, 0.09), transparent 25%),
      linear-gradient(180deg, #fcfbf9 0%, #f4f0ea 100%);
  }
</style>
