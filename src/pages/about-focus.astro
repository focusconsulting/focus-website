---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/shared/PageHero.astro';
import IntroSection from '../components/page-sections/about-focus/IntroSection.astro';
import ValuesSection from '../components/page-sections/about-focus/ValuesSection.astro';
import LeadershipSection from '../components/page-sections/about-focus/LeadershipSection.astro';
import PartnershipsSection from '../components/page-sections/about-focus/PartnershipsSection.astro';


const leaders = [
  {
    name: "Ant Addis",
    title: "Founder & CEO",
    image: "/images/staff/anteneh-avatar-new-sm.png",
    imageAlt: "Portrait of Ant Addis",
    imageClass: "object-[center_18%]",
    linkedinHref: "https://www.linkedin.com/in/ant-addis",
  },
  {
    name: "Michael Kalish",
    title: "Chief Technical Officer",
    image: "/images/staff/kalish-profile.png",
    imageAlt: "Portrait of Michael Kalish",
    imageClass: "object-[center_18%]",
    linkedinHref: "https://www.linkedin.com/in/mqkalish/",
  },
  {
    name: "Phedra Arthur Iruke",
    title: "Chief Delivery Officer",
    image: "/images/staff/phedra.png",
    imageAlt: "Portrait of Phedra Arthur Iruke",
    imageClass: "object-[center_23%]",
    linkedinHref: "#",
  },
];
---

<Layout title="About Focus | Focus">
  <PageHero
    eyebrow="Why we exist"
    fullWidth={true}
    headline="Reduce burden. Simplify policy.<br />Build systems that endure."
    description="We collaborate with our agency partners with intention and speed to deliver critical services to users as early as possible."
  />
  <IntroSection />
  <ValuesSection />
  <LeadershipSection leaders={leaders} />
  <PartnershipsSection />
</Layout>
