---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/shared/PageHero.astro';
import AdjudicatedBenefitsSection from '../components/page-sections/capabilities/AdjudicatedBenefitsSection.astro';
import CapabilitiesSection from '../components/page-sections/capabilities/CapabilitiesSection.astro';
import FunctionalAreasSection from '../components/page-sections/capabilities/FunctionalAreasSection.astro';
import PrinciplesSection from '../components/page-sections/capabilities/PrinciplesSection.astro';
import ExpectationsSection from '../components/page-sections/capabilities/ExpectationsSection.astro';
import TestimonialSection from '../components/page-sections/capabilities/TestimonialSection.astro';
---

<Layout title="Capabilities | Focus">
