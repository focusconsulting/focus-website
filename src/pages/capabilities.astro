---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/shared/PageHero.astro';
import CapabilitiesSection from '../components/page-sections/capabilities/CapabilitiesSection.astro';
import FunctionalAreasSection from '../components/page-sections/capabilities/FunctionalAreasSection.astro';
import PrinciplesSection from '../components/page-sections/capabilities/PrinciplesSection.astro';
import TestimonialSection from '../components/page-sections/capabilities/TestimonialSection.astro';
---

<Layout title="Capabilities | Focus" description="We work alongside agency partners to shape the roadmap and deliver modern systems in increments your teams can adopt and sustain.">
  <PageHero
    eyebrow="How we work"
    headline="Built with your team. Measured by program outcomes."
    description="We work alongside agency partners to understand the service, shape the roadmap, and deliver modern systems in increments your teams can adopt and sustain."
    ctaText="Capability Statement"
    ctaHref="https://drive.google.com/file/d/1wT2xWFwjAdaMEpi2K8TnEs6O9vkADmzO/view"
    ctaDownload={true}
    ctaNewTab={true}
  />
  <PrinciplesSection />
  <CapabilitiesSection />
  <FunctionalAreasSection />  
  <TestimonialSection />
</Layout>
