---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/shared/PageHero.astro';
import ContactSection from '../components/page-sections/contact/ContactSection.astro';
import PartnerWithUsSection from '../components/page-sections/capabilities/PartnerWithUsSection.astro';
---

<Layout title="Contact" description="Tell us about your challenge. We'd like to understand what's actually driving things, what success looks like for you, and share what we've learned from similar work.">
  <PageHero
    eyebrow="Get in touch"
    headline="Partner with us"
    description="Tell us about your challenge. We'll listen carefully, ask what's actually driving things, what success looks like for you, and share what we've learned from similar work. We'll also tell you if we're not a good fit."
    ctaText="Contact Us"
    ctaHref="#contact-section"
  />
  <PartnerWithUsSection />
  <ContactSection />  
</Layout>
