---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/shared/PageHero.astro';
import ContactSection from '../components/page-sections/contact/ContactSection.astro';
import PartnerWithUsSection from '../components/page-sections/capabilities/PartnerWithUsSection.astro';
---

<Layout title="Get in Touch | Focus">
  <PageHero
    eyebrow="Get in touch"
    headline="We're easy to reach."
    description="No pitch deck. No discovery call that turns into a sales call. Just a conversation about what you're working on and whether we're the right fit. If we're not, we'll tell you."
  />
  <ContactSection />
  <PartnerWithUsSection />
</Layout>
