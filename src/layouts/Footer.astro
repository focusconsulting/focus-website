---
const footerGroups = [
  {
    label: "Explore",
    items: [
      { label: "Home", href: "/" },
      { label: "Capabilities", href: "/capabilities" },
      { label: "Our Work", href: "/our-work" },
    ],
  },
  {
    label: "About Focus",
    items: [
      { label: "Mission, Values & Team", href: "/about-focus" },
      { label: "Careers", href: "/careers" },
      { label: "Focus Labs", href: "/focus-labs" },
    ],
  },
];
---

<footer class="section-panel-dark pt-12 pb-8">
  <div class="page-shell flex flex-col items-start justify-between gap-10 md:flex-row md:gap-12">
    <div>
      <a href="/" class="brand-mark-inverse text-[1.5rem] no-underline sm:text-[1.75rem]" aria-label="Focus home">
        focus
      </a>
    </div>
    <div class="grid gap-8 sm:grid-cols-2 md:flex md:gap-14">
      {footerGroups.map((group) => (
        <div class="min-w-0">
          <div class="mb-3 text-sm font-bold text-white">{group.label}</div>
          <div class="flex flex-col gap-1.5 text-[0.95rem]">
            {group.items.map((item) => (
              <a href={item.href} class="text-white/75 no-underline hover:text-white">{item.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div>      
      <div class="mt-4 max-w-[18rem] text-[0.95rem] text-white/50">
        Focus Consulting LLC<br />
        1701 Rhode Island Ave NW, 2nd Floor<br />
        Washington, DC 20036
      </div>
    </div>    
  </div>

  <div class="page-shell mt-6 text-sm text-white/35">
    &copy; 2026 Focus Consulting, LLC. All rights reserved.
  </div>
</footer>
