---
const footerGroups = [
  {
    label: "Explore",
    items: [
      { label: "Home", href: "/" },
      { label: "Capabilities", href: "/capabilities" },
      { label: "Our Work", href: "/our-work" },
    ],
  },
  {
    label: "About Focus",
    items: [
      { label: "Mission, Values & Team", href: "/about-focus" },
      { label: "Careers", href: "/careers" },
      { label: "Focus Labs", href: "/focus-labs" },
    ],
  },
];
---

<footer class="section-panel-dark relative pb-8">
  <div aria-hidden="true" class="absolute inset-x-0 top-0">
    <div class="page-shell">
      <div class="border-t border-[var(--color-brand-border)]/20"></div>
    </div>
  </div>
  <div class="page-shell">
    <div class="grid gap-10 pt-12 md:grid-cols-[auto_auto_1fr] md:items-baseline md:gap-x-12 md:gap-y-8 lg:gap-x-16">
      <div>
        <a href="/" class="brand-mark-inverse text-[1.5rem] no-underline sm:text-[1.75rem]" aria-label="Focus home">
          focus
        </a>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 md:col-start-2 lg:gap-14">
        {footerGroups.map((group) => (
          <div class="min-w-0">
            <div class="mb-3 text-base font-bold text-white">{group.label}</div>
            <div class="flex flex-col gap-1.5 text-[0.95rem]">
              {group.items.map((item) => (
                <a href={item.href} class="text-white/75 no-underline hover:text-white">{item.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="md:col-start-3 md:justify-self-end">
        <!-- <div class="mb-3 text-sm font-bold text-white">Partner with us</div> -->
        <div class="max-w-[18rem] text-[0.95rem] text-white/50">
          Focus Consulting LLC<br />
          1701 Rhode Island Ave NW, 2nd Floor<br />
          Washington, DC&nbsp;&nbsp;20036
        </div>
        <div class="mt-4 flex flex-col gap-3 text-[0.95rem]">
          <a href="/contact" class="text-white/75 no-underline hover:text-white">Contact Us</a>
          <div class="flex items-center gap-3 text-white/75">
            <a
              href="https://github.com/focusconsulting"
              target="_blank"
              rel="noopener"
              aria-label="GitHub"
              class="transition-colors hover:text-white"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 6v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.8A5.3 5.3 0 0 0 18.8 5 4.9 4.9 0 0 0 18.7 1S17.5.7 15 2.4a13.4 13.4 0 0 0-6 0C6.5.7 5.3 1 5.3 1A4.9 4.9 0 0 0 5.2 5a5.3 5.3 0 0 0-1.4 3.7c0 5.3 3.1 6.5 6.1 6.8a3.4 3.4 0 0 0-.9 2.6V22"></path>
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/company/focus-software-consulting/"
              target="_blank"
              rel="noopener"
              aria-label="LinkedIn"
              class="transition-colors hover:text-white"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.94 8.5H3.56V20h3.38V8.5Zm.22-3.56A1.97 1.97 0 0 0 5.25 3a1.98 1.98 0 1 0 0 3.94c1.05 0 1.9-.88 1.9-2Zm12.28 7.92c0-3.46-1.85-5.07-4.32-5.07-1.99 0-2.88 1.09-3.37 1.86V8.5H8.38c.05.76 0 11.5 0 11.5h3.37v-6.42c0-.34.02-.68.13-.92.27-.68.88-1.39 1.9-1.39 1.34 0 1.88 1.02 1.88 2.52V20H19v-6.14Z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell mt-6 text-sm text-white/65">
    &copy; 2026 Focus Consulting, LLC. All rights reserved.
  </div>
</footer>
