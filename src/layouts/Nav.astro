---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: "Capabilities", href: "/capabilities" },
  { label: "About Focus", href: "/about-focus" },
  { label: "Our Work", href: "#" },
  { label: "Insights", href: "#" },
];

const mobileLinks = [
  { label: "Home", href: "/" },
  ...navLinks,
];
---

<nav class="page-shell py-5">
  <div class="flex items-center justify-between gap-6">
    <a href="/" class="brand-mark text-[28px] no-underline sm:text-[32px]" aria-label="Focus home">
      focus
    </a>

    <div class="hidden items-center gap-8 font-normal md:flex">
      {navLinks.map((item) => (
        <a
          href={item.href}
          class:list={["nav-link", item.href === currentPath && "nav-link-current"]}
          aria-current={item.href === currentPath ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
      <a href="#" class="cta-primary px-5 py-2.5 text-[0.95rem]">Get in Touch</a>
    </div>

    <details class="group md:hidden">
      <summary class="flex h-11 w-11 list-none items-center justify-center rounded-full border border-black/[0.08] text-[var(--color-brand-ink)] marker:content-none">
        <span class="sr-only">Toggle navigation</span>
        <span class="flex flex-col gap-1.5">
          <span class="h-0.5 w-5 rounded-full bg-current transition-transform group-open:translate-y-2 group-open:rotate-45"></span>
          <span class="h-0.5 w-5 rounded-full bg-current transition-opacity group-open:opacity-0"></span>
          <span class="h-0.5 w-5 rounded-full bg-current transition-transform group-open:-translate-y-2 group-open:-rotate-45"></span>
        </span>
      </summary>

      <div class="surface-subtle absolute inset-x-6 top-[88px] z-20 border border-[var(--color-brand-border)] p-3 shadow-[0_18px_40px_rgba(26,26,26,0.08)] sm:inset-x-8">
        <div class="flex flex-col">
          {mobileLinks.map((item) => (
            <a
              href={item.href}
              class:list={["nav-link-mobile", item.href === currentPath && "nav-link-current"]}
              aria-current={item.href === currentPath ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
          <a href="#" class="cta-primary mt-3 justify-center px-5 py-3 text-[0.95rem]">Get in Touch</a>
        </div>
      </div>
    </details>
  </div>
</nav>
