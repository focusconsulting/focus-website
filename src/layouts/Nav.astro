---
const currentPath = Astro.url.pathname;

const navGroups = [
  {
    label: "Work",
    items: [
      { label: "How we work", href: "/how-we-work" },
      { label: "Capabilities", href: "#" },
      { label: "Case Studies", href: "#" },
      { label: "Focus Labs", href: "#" },
    ],
  },
  {
    label: "About Focus",
    items: [
      { label: "Mission", href: "#" },
      { label: "Team", href: "#" },
      { label: "Careers", href: "#" },
    ],
  },
];
---

<nav class="page-shell py-5">
  <div class="flex items-center justify-between gap-6">
    <a href="/" class="brand-mark text-[28px] no-underline sm:text-[32px]" aria-label="Focus home">
      focus
    </a>

    <div class="hidden items-center gap-8 font-normal md:flex">
      {navGroups.map((group) => (
        <div class="nav-group">
          <div class="nav-trigger">
            {group.label}
            <span class="nav-caret" aria-hidden="true">
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </span>
          </div>

          <div class="nav-dropdown">
            <div class="nav-dropdown-panel">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class:list={["nav-dropdown-link", item.href === currentPath && "nav-link-current"]}
                  aria-current={item.href === currentPath ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}

      <a href="#" class="nav-link">Insights</a>
      <a href="#" class="cta-primary px-5 py-2.5 text-[0.95rem]">Get In Touch</a>
    </div>

    <details class="group md:hidden">
      <summary class="flex h-11 w-11 list-none items-center justify-center rounded-full border border-black/[0.08] text-[var(--color-brand-ink)] marker:content-none">
        <span class="sr-only">Toggle navigation</span>
        <span class="flex flex-col gap-1.5">
          <span class="h-0.5 w-5 rounded-full bg-current transition-transform group-open:translate-y-2 group-open:rotate-45"></span>
          <span class="h-0.5 w-5 rounded-full bg-current transition-opacity group-open:opacity-0"></span>
          <span class="h-0.5 w-5 rounded-full bg-current transition-transform group-open:-translate-y-2 group-open:-rotate-45"></span>
        </span>
      </summary>

      <div class="surface-subtle absolute inset-x-6 top-[88px] z-20 border border-[var(--color-brand-border)] p-3 shadow-[0_18px_40px_rgba(26,26,26,0.08)] sm:inset-x-8">
        <div class="flex flex-col">
          {navGroups.map((group) => (
            <div class="rounded-md pb-2">
              <div class="px-3 py-2 text-[0.82rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-brand-soft)]">
                {group.label}
              </div>
              <div class="flex flex-col gap-1 pl-3">
                {group.items.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      "nav-dropdown-link text-[0.95rem]",
                      item.href === currentPath && "nav-link-current",
                    ]}
                    aria-current={item.href === currentPath ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          ))}

          <a href="#" class="nav-link-mobile">Insights</a>
          <a href="#" class="cta-primary mt-3 justify-center px-5 py-3 text-[0.95rem]">Get In Touch</a>
        </div>
      </div>
    </details>
  </div>
</nav>
